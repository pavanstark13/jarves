# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jarves:jarves@localhost:5432/jarves
REDIS_URL=redis://localhost:6379

# ── AI (Anthropic Claude) ────────────────────────────────────────────────────
# Free: 15 RPM, 1M tokens/day — get key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# ANTHROPIC removed — using Google Gemini instead

# ── Market Data (Twelve Data) ────────────────────────────────────────────────
# Free: 800 API calls/day — https://twelvedata.com
TWELVE_DATA_API_KEY=

# ── News (NewsAPI) ───────────────────────────────────────────────────────────
# Free: 100 requests/day — https://newsapi.org
NEWS_API_KEY=

# ── Economic Calendar (FCS API) ──────────────────────────────────────────────
FCS_API_KEY=

# ── OANDA Practice Account ────────────────────────────────────────────────────
# Free practice account: https://www.oanda.com/us-en/trading/demo-account/
# After creating account: My Services → Manage API Access → Generate token
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_PRACTICE=true

# ── Risk Parameters ───────────────────────────────────────────────────────────
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_MAX_WEEKLY_LOSS_PCT=5.0
RISK_MAX_DRAWDOWN_PCT=10.0
RISK_DEFAULT_RISK_PCT=0.5

# ── Strategy Thresholds ───────────────────────────────────────────────────────
MIN_SETUP_QUALITY=70
MIN_RISK_REWARD=1.5

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
