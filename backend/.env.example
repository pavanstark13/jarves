# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jarves:jarves@localhost:5432/jarves
REDIS_URL=redis://localhost:6379

# ── AI (Anthropic Claude) ────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Market Data (Twelve Data) ────────────────────────────────────────────────
# Free: 800 API calls/day, 8/min — no credit card required
# Sign up at https://twelvedata.com
TWELVE_DATA_API_KEY=

# ── News (NewsAPI) ───────────────────────────────────────────────────────────
# Free: 100 requests/day for development plan
# Sign up at https://newsapi.org
NEWS_API_KEY=

# ── Economic Calendar (FCS API) ──────────────────────────────────────────────
# Free tier available — sign up at https://fcsapi.com
FCS_API_KEY=

# ── Risk Parameters ───────────────────────────────────────────────────────────
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_MAX_WEEKLY_LOSS_PCT=5.0
RISK_MAX_DRAWDOWN_PCT=10.0
RISK_DEFAULT_RISK_PCT=0.5

# ── Strategy Thresholds ───────────────────────────────────────────────────────
MIN_SETUP_QUALITY=70
MIN_RISK_REWARD=1.5

# ── Broker (MT5 / cTrader — Phase 4) ─────────────────────────────────────────
BROKER_API_KEY=
BROKER_API_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
